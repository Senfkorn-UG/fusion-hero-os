{
  "tagOwners": {
    "tag:fusion-node-desktop": ["stephan95g@googlemail.com"],
    "tag:fusion-node-mainframe": ["stephan95g@googlemail.com"],
    "tag:fusion-node-phone": ["stephan95g@googlemail.com"],
    "tag:fusion-agent-researcher": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-github": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-gmail": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-google-drive": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-google-calendar": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-canva": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-gamma": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-notion": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-vercel": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-hyperframes": ["stephan95g@googlemail.com"],
    "tag:fusion-connector-tasks": ["stephan95g@googlemail.com"]
  },

  "hosts": {
    // Endgeraet des Superusers Stephan Urban (Phone)
    "handy-stephan": "100.108.67.116",
    // Workstation (dieser PC - desktop-kpki9e4)
    "pc": "100.64.104.58"
  },

  "acls": [
    // Alle Heroic Mesh Geräte (Nodes + Agent + Connectors) haben vollen Zugriff untereinander und auf pc
    {
      "action": "accept",
      "src": [
        "tag:fusion-node-desktop",
        "tag:fusion-node-mainframe",
        "tag:fusion-node-phone",
        "tag:fusion-agent-researcher",
        "tag:fusion-connector-github",
        "tag:fusion-connector-gmail",
        "tag:fusion-connector-google-drive",
        "tag:fusion-connector-google-calendar",
        "tag:fusion-connector-canva",
        "tag:fusion-connector-gamma",
        "tag:fusion-connector-notion",
        "tag:fusion-connector-vercel",
        "tag:fusion-connector-hyperframes",
        "tag:fusion-connector-tasks",
        "handy-stephan",
        "pc"
      ],
      "dst": ["*:*"]
    }
  ],

  "ssh": [
    {
      "action": "accept",
      "src": ["autogroup:member"],
      "dst": ["autogroup:self"],
      "users": ["autogroup:nonroot", "root"]
    }
  ]
}
