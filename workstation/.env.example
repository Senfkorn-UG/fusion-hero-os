# Fusion Hero OS v8 — LLM API Keys
# Kopiere nach .env und trage deine Keys ein (NIEMALS committen!)

# Grok / xAI
XAI_API_KEY=
GROK_API_KEY=

# Claude / Anthropic
ANTHROPIC_API_KEY=

# GPT / OpenAI
OPENAI_API_KEY=

# Gemini / Google
GOOGLE_API_KEY=
GEMINI_API_KEY=

# OpenRouter (Fallback-Gateway)
OPENROUTER_API_KEY=

# Ollama (lokal, kein Key nötig)
OLLAMA_HOST=http://127.0.0.1:11434

# Tailscale Mesh — Windows-Desktop = Mainframe
FUSION_MESH_MAINFRAME_NODE=mainframe
FUSION_MESH_MAINFRAME_HOSTNAME=desktop-kpki9e4
FUSION_MESH_MAINFRAME_MAGICDNS=host.example.ts.net
FUSION_MESH_BASE_URL=https://host.example.ts.net

# Optionale Model-Overrides
FUSION_GROK_MODEL=grok-2-latest
FUSION_CLAUDE_MODEL=claude-3-5-sonnet-20241022
FUSION_GPT_MODEL=gpt-4o-mini
FUSION_GEMINI_MODEL=gemini-2.0-flash
FUSION_OLLAMA_MODEL=llama3.2
FUSION_TRINITY_MAX_MODELS=3
FUSION_MODEL_TIMEOUT=90