{
  "version": "1.0",
  "updated": "2026-07-13",
  "policy_id": "google_drive_cold_default",
  "principle": "Dokumente, Archive, Medien und nicht-operative Daten liegen standardmaessig in Google Drive. Lokal bleiben nur operative Systeme (Code, laufende Dienste, aktive Builds).",
  "vault_repo": "95guknow/fusion-hero-vault",
  "google_drive": {
    "mount_candidates": [
      "{USERPROFILE}\\Google Drive-Streaming",
      "{USERPROFILE}\\Google Drive"
    ],
    "library": "Meine Ablage",
    "cold_root": "FusionHero_Offload",
    "photo_ingestion": "ALTE_Frau_95g_Photo_Ingestion"
  },
  "operational_local": [
    "fusion-hero-os",
    "normalOS",
    "Programs",
    "src",
    ".cargo",
    ".rustup",
    "venv",
    "AppData\\Local\\Programs",
    "node_modules",
    ".fusion",
    ".fusion-hero-os"
  ],
  "cold_subfolders": {
    "documents": "Documents_Archive",
    "downloads": "Downloads_Archive",
    "desktop": "Desktop_Archive",
    "archives": "Archives",
    "sd_models": "SD_models",
    "llm_models": "LLM_models",
    "photos_dcim": "ALTE_Frau_95g_Photo_Ingestion/DCIM_PC"
  },
  "offload_folders": [
    {"src": "stable-diffusion-webui/models", "dst": "SD_models"},
    {"src": "internal_llm/models", "dst": "LLM_models"},
    {"src": "private-hacking-suite", "dst": "Archives/private-hacking-suite"},
    {"src": ".grok/sessions", "dst": "Archives/grok_sessions"},
    {"src": ".grok/downloads", "dst": "Archives/grok_downloads"}
  ],
  "thresholds": {
    "offload_min_mb": 50,
    "dedup_min_mb": 1,
    "sweep_min_mb": 20
  },
  "scripts": {
    "apply": "workstation/apply-storage-policy.ps1",
    "offload": "workstation/offload-to-gdrive.ps1",
    "sweep": "workstation/offload-full-sweep.ps1",
    "tool": "tools/disk_dedup_offload.py"
  }
}
