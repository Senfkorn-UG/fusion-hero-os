# .env.example – Vorlage für API-Schlüssel
# Bitte in .env umbenennen und echte Werte eintragen.

# Supabase (Client-Konfiguration)
# PUBLISHABLE_KEY ist per Design öffentlich (Browser-Code), abgesichert über RLS.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Gemini API (Google Generative AI)
GEMINI_API_KEY=

# Optional: weitere Dienste
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# REPLICATE_API_TOKEN=
