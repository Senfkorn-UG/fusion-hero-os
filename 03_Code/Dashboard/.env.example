# .env.example – Vorlage für API-Schlüssel
# Bitte in .env umbenennen und echte Werte eintragen.

# ============================================================================
# ACHTUNG: SUPABASE_PROJECT_REF unten (YOUR_SUPABASE_PROJECT_REF) ist die
# APP-eigene Datenbank des Dashboards — ein ANDERES Projekt als der neue
# Fusion Vault (fusion-hero-secrets-vault, ref uszptbmbcwiaesootfwv, siehe
# ../../.env.example). NICHT verwechseln/zusammenlegen, unterschiedliche
# Zwecke. Konnte bei der Konsolidierung 2026-07-12 nicht verifiziert werden,
# ob YOUR_SUPABASE_PROJECT_REF noch existiert (list_projects zeigte für die
# verbundene Supabase-Org keine Projekte) — vor Nutzung pruefen.
# ============================================================================

# Supabase (Client-Konfiguration, App-Backend des Dashboards)
# Projekt: https://supabase.com/dashboard/project/YOUR_SUPABASE_PROJECT_REF
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=https://project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_PROJECT_REF=YOUR_SUPABASE_PROJECT_REF

# Legacy-Aliase (optional, gleiche Werte wie oben)
PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
PUBLIC_SUPABASE_PROJECT_REF=YOUR_SUPABASE_PROJECT_REF

# Provider-Keys (Gemini, Anthropic, ...): bevorzugt ueber den Fusion Vault
# beziehen (siehe Repo-Root ../../.env.example), nicht mehr direkt hier
# eintragen. Als lokaler Fallback weiterhin moeglich:
GEMINI_API_KEY=

# Claude Science (Anthropic API — Windows: API-Bridge, native App: macOS/Linux)
ANTHROPIC_API_KEY=
CLAUDE_SCIENCE_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages

# Domänen/Modus-Erkennung (Sprachanpassung, DE+EN) — Laufzeit-Override
# Zeigt auf eine JSON-Datei mit zusätzlichen/überschreibenden Keywords je Modus.
# Vorlage: 03_Code/core/domain_keywords.example.json. Leer = nur Builtins bzw.
# Default-Pfad ~/.fusion-hero-os/domain_keywords.json (falls vorhanden).
# FUSION_DOMAIN_KEYWORDS_FILE=

# Optional: weitere Dienste
# OPENAI_API_KEY=
# REPLICATE_API_TOKEN=
