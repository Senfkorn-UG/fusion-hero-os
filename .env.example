# Fusion Hero OS — Runtime Config (kanonische Vorlage)
# Kopiere nach .env. NIEMALS committen!
#
# Diese Datei ist die EINZIGE kanonische .env.example fuer fusion-hero-os
# (ersetzt workstation/.env.example, die frueher eine Teilmenge davon war).
#
# ============================================================================
# FUSION VAULT — zentraler Secrets-Broker (Supabase, Projekt
# fusion-hero-secrets-vault, ref uszptbmbcwiaesootfwv)
# ============================================================================
# Provider-API-Keys (Anthropic/OpenAI/Gemini/Grok/...) werden NICHT mehr
# direkt in .env eingetragen. Jeder Agent-Node authentifiziert sich mit
# einem eigenen, engen Token gegen den Vault und holt sich Secrets als
# kurzlebige Lease (siehe src/normal_os/connectors/vault_client.py).
# Diese drei Werte liegen NICHT hier, sondern in
# ~/.fusion_agent_credentials (chmod 600, pro Node individuell):
#   FUSION_VAULT_URL=https://uszptbmbcwiaesootfwv.supabase.co
#   FUSION_AGENT_ID=<node-name, z.B. claude-agent>
#   FUSION_AGENT_TOKEN=<pro Node individuell, vom Admin vergeben>
#
# Optional: lokaler Fallback fuer Kontexte, die (noch) nicht ueber den Vault
# laufen (z.B. schnelles Ad-hoc-Debugging auf dem Mainframe). Nur setzen,
# wenn wirklich noetig — bevorzugt den Vault nutzen.
# XAI_API_KEY=
# GROK_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# MISTRAL_API_KEY=
# HUGGINGFACE_API_KEY=
# GITHUB_TOKEN=

# Ollama (lokal, kein Key noetig — nicht im Vault, da kein Secret)
OLLAMA_HOST=http://127.0.0.1:11434

# Externe Konnektoren (Slack, Jira, Files, Gmail/Calendar, GitHub, Finance,
# OpticOdds) laufen server-seitig ueber die `external-tool`-CLI — KEINE Secrets
# hier noetig. Optional: Pfad zur CLI, falls nicht auf PATH.
# FUSION_EXTERNAL_TOOL_BIN=external-tool

# Optionale Model-Overrides
FUSION_GROK_MODEL=grok-2-latest
FUSION_CLAUDE_MODEL=claude-3-5-sonnet-20241022
FUSION_GPT_MODEL=gpt-4o-mini
FUSION_GEMINI_MODEL=gemini-2.0-flash
FUSION_OLLAMA_MODEL=llama3.2
FUSION_TRINITY_MAX_MODELS=3
FUSION_MODEL_TIMEOUT=90
DEFAULT_PROVIDER=openrouter
FALLBACK_PROVIDERS=groq,gemini,huggingface,github

# ============================================================================
# AGENT CONTROL & VERIFICATION
# ============================================================================

FUSION_AGENT_CONTROL=1
FUSION_AGENT_CONTROL_FAIL_CLOSED=1
FUSION_AGENT_CONTROL_STRATEGIES=geltung,peer_review,meta,audit,echtwelt,nli_backward,provenance
FUSION_AGENT_CONTROL_MIN_VOTES=2

FUSION_ECHTWELT_VERIFY=1
FUSION_ECHTWELT_MIN_SCORE=0.5
FUSION_ECHTWELT_TIMEOUT=8
FUSION_ECHTWELT_MAX_CLAIMS=5

FUSION_NLI_VERIFY=1
FUSION_NLI_MIN_ATTRIBUTION=0.5
FUSION_NLI_MIN_ENTAILS=0.5
FUSION_NLI_MAX_SENTENCES=12
FUSION_NLI_SPAN_WINDOW=280
FUSION_NLI_TIMEOUT=12

FUSION_PROV_TRACE=1
FUSION_PROV_MIN_COMPLETENESS=0.6
FUSION_PROV_MAX_TRACES=500

FUSION_VERIFY_ORCHESTRATOR=1
FUSION_VERIFY_RECOVERY=1
FUSION_VERIFY_LLM_RECOVERY=1
FUSION_VERIFY_RECOVERY_MAX_ITERS=2
FUSION_VERIFY_LLM_TIMEOUT=45
FUSION_VERIFY_STAKES=medium
FUSION_VERIFY_LATENCY_MS=900

# Tailscale Mesh — Windows-Desktop = Mainframe
FUSION_MESH_MAINFRAME_NODE=mainframe
FUSION_MESH_MAINFRAME_HOSTNAME=desktop-kpki9e4
FUSION_MESH_MAINFRAME_MAGICDNS=host.example.ts.net
FUSION_MESH_BASE_URL=https://host.example.ts.net
