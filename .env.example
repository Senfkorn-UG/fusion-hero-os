# Fusion Hero OS - LLM Provider Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# FREE TIER PROVIDERS (Recommended for maximum free models)
# ============================================================================

# Google AI Studio (Gemini) - Very generous free tier
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenRouter - Access to 100+ models including many free ones
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq - Ultra-fast inference (Llama, Qwen, Gemma, DeepSeek, Mistral)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras - Extremely fast Llama inference
# Get key: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Mistral AI - Free tier available
# Get key: https://console.mistral.ai/
MISTRAL_API_KEY=

# Hugging Face Inference API - Thousands of open-source models
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# GitHub Models - Free frontier models via GitHub
# Get token: https://github.com/settings/tokens (needs "models" scope)
GITHUB_TOKEN=

# ============================================================================
# AGENT CONTROL & ECHTWELT VERIFICATION
# ============================================================================

# Globale Output-Kontrolle (geltung, peer_review, meta, audit, echtwelt, nli_backward, provenance)
FUSION_AGENT_CONTROL=1
FUSION_AGENT_CONTROL_FAIL_CLOSED=1
FUSION_AGENT_CONTROL_STRATEGIES=geltung,peer_review,meta,audit,echtwelt,nli_backward,provenance
FUSION_AGENT_CONTROL_MIN_VOTES=2

# Echtweltquellen-Prüfung: URLs, Web-Suche, Task-Sources
FUSION_ECHTWELT_VERIFY=1
FUSION_ECHTWELT_MIN_SCORE=0.5
FUSION_ECHTWELT_TIMEOUT=8
FUSION_ECHTWELT_MAX_CLAIMS=5

# Stufe 2: NLI backward-pass gegen RAG-Quellen (Span-Attribution)
FUSION_NLI_VERIFY=1
FUSION_NLI_MIN_ATTRIBUTION=0.5
FUSION_NLI_MIN_ENTAILS=0.5
FUSION_NLI_MAX_SENTENCES=12
FUSION_NLI_SPAN_WINDOW=280
FUSION_NLI_TIMEOUT=12
# FUSION_NLI_USE_HF=1  # optional: Hugging Face NLI (benötigt HUGGINGFACE_API_KEY)

# Stufe 3: Execution Provenance (OpenTelemetry-Spans + W3C PROV-DM)
FUSION_PROV_TRACE=1
FUSION_PROV_MIN_COMPLETENESS=0.6
# FUSION_PROV_STORE_DIR=/path/to/provenance
FUSION_PROV_MAX_TRACES=500

# Unified Verification Orchestrator + Recovery Loop
FUSION_VERIFY_ORCHESTRATOR=1
FUSION_VERIFY_RECOVERY=1
FUSION_VERIFY_RECOVERY_MAX_ITERS=2
FUSION_VERIFY_STAKES=medium
FUSION_VERIFY_LATENCY_MS=900


# Tailscale Mesh — Windows-Desktop = Mainframe (orchestrator)
FUSION_MESH_MAINFRAME_NODE=mainframe
FUSION_MESH_MAINFRAME_HOSTNAME=desktop-kpki9e4
FUSION_MESH_MAINFRAME_MAGICDNS=host.example.ts.net
FUSION_MESH_BASE_URL=https://host.example.ts.net


# Fallback providers in order (used when primary fails)
FALLBACK_PROVIDERS=groq,gemini,huggingface,github

# ============================================================================
# OPTIONAL: OTHER PROVIDERS
# ============================================================================

# Together AI
# TOGETHER_API_KEY=

# Fireworks AI
# FIREWORKS_API_KEY=

# Cohere
# COHERE_API_KEY=

# NVIDIA NIM
# NVIDIA_API_KEY=

# Cloudflare Workers AI
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_ACCOUNT_ID=
