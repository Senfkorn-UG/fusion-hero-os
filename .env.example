# Fusion Hero OS — LLM API Keys & Runtime Config
# Kopiere nach .env und trage deine Keys ein (NIEMALS committen!)

# Grok / xAI
XAI_API_KEY=
GROK_API_KEY=

# Claude / Anthropic
ANTHROPIC_API_KEY=

# GPT / OpenAI
OPENAI_API_KEY=

# Gemini / Google
GOOGLE_API_KEY=
GEMINI_API_KEY=

# OpenRouter (Fallback-Gateway)
OPENROUTER_API_KEY=

# Groq / Cerebras / Mistral / Hugging Face / GitHub Models
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
GITHUB_TOKEN=

# Ollama (lokal, kein Key nötig)
OLLAMA_HOST=http://127.0.0.1:11434

# Optionale Model-Overrides
FUSION_GROK_MODEL=grok-2-latest
FUSION_CLAUDE_MODEL=claude-3-5-sonnet-20241022
FUSION_GPT_MODEL=gpt-4o-mini
FUSION_GEMINI_MODEL=gemini-2.0-flash
FUSION_OLLAMA_MODEL=llama3.2
FUSION_TRINITY_MAX_MODELS=3
FUSION_MODEL_TIMEOUT=90
DEFAULT_PROVIDER=openrouter
FALLBACK_PROVIDERS=groq,gemini,huggingface,github

# ============================================================================
# AGENT CONTROL & VERIFICATION
# ============================================================================

FUSION_AGENT_CONTROL=1
FUSION_AGENT_CONTROL_FAIL_CLOSED=1
FUSION_AGENT_CONTROL_STRATEGIES=geltung,peer_review,meta,audit,echtwelt,nli_backward,provenance
FUSION_AGENT_CONTROL_MIN_VOTES=2

FUSION_ECHTWELT_VERIFY=1
FUSION_ECHTWELT_MIN_SCORE=0.5
FUSION_ECHTWELT_TIMEOUT=8
FUSION_ECHTWELT_MAX_CLAIMS=5

FUSION_NLI_VERIFY=1
FUSION_NLI_MIN_ATTRIBUTION=0.5
FUSION_NLI_MIN_ENTAILS=0.5
FUSION_NLI_MAX_SENTENCES=12
FUSION_NLI_SPAN_WINDOW=280
FUSION_NLI_TIMEOUT=12

FUSION_PROV_TRACE=1
FUSION_PROV_MIN_COMPLETENESS=0.6
FUSION_PROV_MAX_TRACES=500

FUSION_VERIFY_ORCHESTRATOR=1
FUSION_VERIFY_RECOVERY=1
FUSION_VERIFY_RECOVERY_MAX_ITERS=2
FUSION_VERIFY_STAKES=medium
FUSION_VERIFY_LATENCY_MS=900

# Tailscale Mesh — Windows-Desktop = Mainframe
FUSION_MESH_MAINFRAME_NODE=mainframe
FUSION_MESH_MAINFRAME_HOSTNAME=desktop-kpki9e4
FUSION_MESH_MAINFRAME_MAGICDNS=desktop-kpki9e4.tail391adb.ts.net
FUSION_MESH_BASE_URL=https://desktop-kpki9e4.tail391adb.ts.net
